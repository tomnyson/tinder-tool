{
    "manifest_version": 3,
    "name": "Tinder matches",
    "version": "1.2",
    "description": "Extension để tự động click vào gamepad icon trên trang Tinder, gửi tin nhắn hàng loạt, và tạo tin nhắn bằng AI OpenRouter",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://tinder.com/*"
            ],
            "js": [
                "tinder-auto-click.js"
            ],
            "run_at": "document_idle"
        }
    ]
}